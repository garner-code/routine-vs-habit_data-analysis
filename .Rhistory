x <- matrix(data=c(3, 2, 1, 5, 6, 4, 2, 3, 1), nrow=3)
x
classic <- x / apply(apply(x, 1, sum), 2, sum)
sum(x)
classic <- x / sum(x)
sum(x)
sum(classic)
classic*log(classic)
sum(classic*log(classic))
TE <- x
TE_norm <- apply(TE, 1, sum)
TE
TE_norm
