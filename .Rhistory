reclicks = first(reclicks),
accuracy = n_cc / n_clicks,
setting_errors = n_oc / n_clicks,
general_errors = n_nc / n_clicks,
) %>% ungroup()
fnl <- file.path(project_path, "res", paste(paste(exp, "trl", sep = "_"), ".csv", sep = ""))
